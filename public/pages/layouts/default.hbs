<!--
 * location: ~/public/pages/layouts/default.hbs
 * description: This HBS file sets up the basic structure and necessary resources for a web page.
 * 							It includes metadata for character set and viewport settings, links to external CSS
 * 							and JavaScript libraries (such as jQuery and Bootstrap), and placeholders for the
 * 							title and body content.
 * installation: Save this file with a .hbs extension and open it in a web browser to render the
 * 							 page.
 * usage: Replace {{title}} with your desired page title and {{body}} with your content. Customize
 *			  the links to assets and libraries as needed for your project.
-->

<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/x-icon" href="../../assets/truck.png" />
		<link rel="stylesheet" href="https://releases.jquery.com/git/ui/jquery-ui-git.css" />
		<link
			href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
			rel="stylesheet"
			integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
			crossorigin="anonymous"
		/>
		<script
			src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
			integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
			crossorigin="anonymous"
		></script>
		<script
			src="https://code.jquery.com/jquery-3.7.1.js"
			integrity="sha256-eKhayi8LEQwp4NKxN+CfCh+3qOVUtJn3QNZ0TciWLP4="
			crossorigin="anonymous"
		></script>
		<script
			src="https://code.jquery.com/ui/1.14.1/jquery-ui.js"
			integrity="sha256-9zljDKpE/mQxmaR4V2cGVaQ7arF3CcXxarvgr7Sj8Uc="
			crossorigin="anonymous"
		></script>
		<title>
			{{title}}
		</title>
	</head>

	<body>
		{{{body}}}
	</body>
</html>